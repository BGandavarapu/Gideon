# ============================================================
# Gideon - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Google Gemini API (free tier - get key at https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Database
# Option A: full SQLAlchemy URL (takes priority)
#   SQLite:     DATABASE_URL=sqlite:///data/jobs.db
#   PostgreSQL: DATABASE_URL=postgresql+psycopg2://user:password@localhost/resume_tailor
DATABASE_URL=

# Option B: SQLite shorthand path (used when DATABASE_URL is blank)
DATABASE_PATH=data/jobs.db

# Notification Settings (optional - leave blank to disable)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
NOTIFY_EMAIL=
